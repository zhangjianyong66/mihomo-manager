#!/bin/bash
#
# Mihomo 管理脚本 - 精简版
# 主命令分发器，功能通过 lib 目录下的模块实现
#

set -e

# 获取脚本所在目录（处理符号链接）
SCRIPT_SOURCE="${BASH_SOURCE[0]}"
# 循环解析符号链接（兼容 macOS 和 Linux）
while [[ -L "$SCRIPT_SOURCE" ]]; do
    LINK_TARGET=$(readlink "$SCRIPT_SOURCE")
    if [[ "${LINK_TARGET:0:1}" == "/" ]]; then
        # 绝对路径
        SCRIPT_SOURCE="$LINK_TARGET"
    else
        # 相对路径
        SCRIPT_SOURCE="$(dirname "$SCRIPT_SOURCE")/$LINK_TARGET"
    fi
done
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_SOURCE")" && pwd)"
LIB_DIR="$SCRIPT_DIR/../scripts/lib"

# 加载所有库
source "$LIB_DIR/common.sh"
source "$LIB_DIR/service.sh"
source "$LIB_DIR/subscription.sh"
source "$LIB_DIR/whitelist.sh"
source "$LIB_DIR/routing.sh"

# 注册清理函数
mm_register_cleanup

# ============================================
# 帮助信息
# ============================================

show_help() {
    cat << 'EOF'
Mihomo 管理脚本

用法: mihomo-manager <命令> [选项]

服务管理:
  status (st)         查看服务状态
  start               启动服务
  stop (sp)           停止服务
  restart (r)         重启服务
  reload (rl)         热重载配置
  logs (l)            查看实时日志
  test (t)            测试配置文件

节点管理:
  list (ls)           列出所有节点
  current (c)         显示当前节点
  switch (swc) <节点|序号> 切换到指定节点
  test-current (tc)   测试当前生效节点延迟
  test-nodes (tn)     测试所有节点延迟
  fastest (f) [N]     自动切换到最快节点（测到 N 个可用节点后停止）

订阅管理:
  update-sub (us)     更新订阅配置
  update (upd)        从保存的订阅URL更新配置
  save-url (su)       保存订阅URL
  show-url (sw)       显示已保存的订阅URL

白名单管理:
  whitelist (wl)      白名单管理（直连不走代理）
  rcn                 一键配置：大陆直连，其他走代理

配置管理:
  backup (bk)         备份当前配置
  restore (rs)        恢复备份配置
  edit (e)            编辑配置文件

白名单子命令:
  whitelist add <域名>     添加域名到白名单
  whitelist remove <域名>  从白名单移除域名
  whitelist list           列出白名单

选项:
  -u, --url URL   指定订阅链接（用于 update-sub）
  --save-url      同时保存订阅URL到配置文件
  --proxy         使用代理下载订阅（默认不走代理）
  -h, --help      显示帮助
  -v, --version   显示版本

示例:
  mm status                       # 或 mm st
  mm restart                      # 或 mm r
  mm save-url https://example.com/sub
  mm us -u 'https://example.com/sub' --save-url
  mm list                         # 或 mm ls
  mm switch '节点名称'            # 或 mm swc '节点名称'
  mm switch 3                     # 或 mm swc 3 (切换到第3个节点)
  mm test-nodes                   # 或 mm tn
  mm fastest                      # 或 mm f（测试所有节点）
  mm fastest 5                    # 或 mm f 5（找到 5 个可用节点后切换）
  mm whitelist add example.com    # 或 mm wl add example.com
  mm rcn                          # 大陆直连，其他走代理
EOF
}

# ============================================
# 主函数
# ============================================

main() {
    local command=""
    local url=""
    local use_proxy="false"
    local save_url="false"
    local switch_node_name=""
    local extra_args=""
    
    # 解析参数
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)
                show_help
                exit 0
                ;;
            -v|--version)
                echo "mihomo-manager version $(mm_version)"
                exit 0
                ;;
            -u|--url)
                if [[ -n "${2:-}" && "${2#-}" == "$2" ]]; then
                    url="$2"
                    shift 2
                else
                    mm_error "选项 --url 需要参数"
                    exit 1
                fi
                ;;
            --proxy)
                use_proxy="true"
                shift
                ;;
            --save-url)
                save_url="true"
                shift
                ;;
            -*)
                mm_error "未知选项: $1"
                show_help
                exit 1
                ;;
            *)
                if [[ -z "$command" ]]; then
                    command="$1"
                    shift
                    # 对于需要收集剩余参数的命令
                    case "$command" in
                        save-url|su)
                            extra_args="$*"
                            break
                            ;;
                        switch|swc)
                            extra_args="$*"
                            break
                            ;;
                        fastest|f)
                            extra_args="$*"
                            break
                            ;;
                        whitelist|wl)
                            extra_args="$*"
                            break
                            ;;
                    esac
                else
                    mm_error "多余的参数: $1"
                    exit 1
                fi
                ;;
        esac
    done
    
    # 无命令时显示帮助
    if [[ -z "$command" ]]; then
        show_help
        exit 0
    fi
    
    # 帮助命令不需要检查依赖
    case "$command" in
        -h|--help|help)
            show_help
            exit 0
            ;;
    esac
    
    # 检查基本依赖（帮助命令除外）
    mm_check_all || exit 1
    
    # 命令分发
    case "$command" in
        # 服务管理
        status|st)
            mm_show_status
            ;;
        start)
            mm_start_service
            ;;
        stop|sp)
            mm_stop_service
            ;;
        restart|r)
            mm_restart_service
            ;;
        reload|rl)
            mm_reload_config
            ;;
        logs|l)
            mm_show_logs
            ;;
        test|t)
            if mm_test_config; then
                mm_success "配置文件测试通过"
            else
                mm_error "配置文件测试失败"
                exit 1
            fi
            ;;
        
        # 节点管理
        list|ls)
            mm_list_nodes
            ;;
        current|c)
            mm_show_current_node
            ;;
        switch|swc)
            if [[ -z "$extra_args" ]]; then
                mm_error "请指定节点名称"
                mm_info "用法: mm switch <节点名|序号>"
                exit 1
            fi
            mm_switch_node "$extra_args"
            ;;
        test-current|tc)
            mm_test_current_node
            ;;
        test-nodes|tn)
            mm_test_nodes
            ;;
        fastest|f)
            mm_switch_to_fastest "$extra_args"
            ;;
        
        # 订阅管理
        update-sub|us)
            if mm_download_subscription "$url" "$use_proxy"; then
                if [[ "$save_url" == "true" && -n "$url" ]]; then
                    mm_save_subscription_url "$url"
                fi
            fi
            ;;
        update|upd)
            mm_update_from_saved_url
            ;;
        save-url|su)
            mm_save_subscription_url "$extra_args"
            ;;
        show-url|sw)
            mm_show_subscription_url
            ;;
        
        # 配置管理
        backup|bk)
            mm_backup_config
            ;;
        restore|rs)
            mm_restore_config
            ;;
        edit|e)
            mm_edit_config
            ;;
        
        # 白名单管理
        whitelist|wl)
            # 解析白名单子命令
            local wl_subcmd=""
            local wl_arg=""
            
            if [[ -n "$extra_args" ]]; then
                wl_subcmd=$(echo "$extra_args" | awk '{print $1}')
                wl_arg=$(echo "$extra_args" | awk '{print $2}')
            fi
            
            case "$wl_subcmd" in
                add|a)
                    mm_whitelist_add "$wl_arg"
                    ;;
                remove|rm|r)
                    mm_whitelist_remove "$wl_arg"
                    ;;
                list|ls|l|"")
                    mm_whitelist_list
                    ;;
                help|h|--help)
                    mm_whitelist_help
                    ;;
                *)
                    # 直接传入域名，默认执行 add
                    mm_whitelist_add "$wl_subcmd"
                    ;;
            esac
            ;;

        # 分流管理
        rcn|route-cn)
            mm_route_cn_apply
            ;;
        
        # 未知命令
        *)
            mm_error "未知命令: $command"
            show_help
            exit 1
            ;;
    esac
}

# 运行主函数
main "$@"
