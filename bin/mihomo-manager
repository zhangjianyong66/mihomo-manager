#!/bin/bash
#
# Mihomo 管理脚本
# 用于重启服务、修改订阅配置等操作
#

set -e

# 临时文件清理
cleanup_temp_files() {
    rm -f /tmp/mihomo_nodes_$$.txt /tmp/mihomo_results_$$.txt \
          /tmp/mihomo_encoded_$$.txt /tmp/mihomo_delay_$$.json \
          /tmp/mihomo_sub_*.yaml 2>/dev/null || true
}
trap cleanup_temp_files EXIT

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# 配置路径
MIHOMO_BIN="$HOME/.local/bin/mihomo"
CONFIG_DIR="$HOME/.config/mihomo"
CONFIG_FILE="$CONFIG_DIR/config.yaml"
CONFIG_BACKUP="$CONFIG_DIR/config.yaml.bak"
PID_FILE="$CONFIG_DIR/mihomo.pid"
SUBSCRIPTION_URL_FILE="$CONFIG_DIR/subscription.url"

# 订阅配置（用于替换）
SUBSCRIPTION_URL=""

# 检查依赖
check_dependencies() {
    if [ ! -x "$MIHOMO_BIN" ]; then
        print_error "Mihomo 二进制不存在或不可执行: $MIHOMO_BIN"
        exit 1
    fi
    if [ ! -d "$CONFIG_DIR" ]; then
        print_error "配置目录不存在: $CONFIG_DIR"
        exit 1
    fi
    if [ ! -f "$CONFIG_FILE" ]; then
        print_warning "配置文件不存在: $CONFIG_FILE"
        print_info "请先使用 update-sub 或 save-url 命令配置订阅"
    fi
}

# 显示帮助信息
show_help() {
    echo "Mihomo 管理脚本"
    echo ""
    echo "用法: mihomo-manager <命令> [选项]"
    echo ""
    echo "命令:"
    echo "  status (st)         查看服务状态"
    echo "  start               启动服务"
    echo "  stop (sp)           停止服务"
    echo "  restart (r)         重启服务"
    echo "  reload (rl)         热重载配置"
    echo "  update-sub (us)     更新订阅配置"
    echo "  update (upd)        从保存的订阅URL更新配置"
    echo "  save-url (su)       保存订阅URL"
    echo "  show-url (sw)       显示已保存的订阅URL"
    echo "  backup (bk)         备份当前配置"
    echo "  restore (rs)        恢复备份配置"
    echo "  test (t)            测试配置文件"
    echo "  logs (l)            查看实时日志"
    echo "  edit (e)            编辑配置文件"
    echo "  list (ls)           列出所有节点"
    echo "  current (c)         显示当前节点"
    echo "  switch (swc) <节点> 切换到指定节点"
    echo "  test-nodes (tn)     测试节点延迟"
    echo "  fastest (f)         自动切换到最快节点"
    echo "  whitelist (wl)      白名单管理（直连不走代理）"
    echo ""
    echo "白名单子命令:"
    echo "  whitelist add <域名>     添加域名到白名单"
    echo "  whitelist remove <域名>  从白名单移除域名"
    echo "  whitelist list           列出白名单"
    echo ""
    echo "选项:"
    echo "  -u, --url URL   指定订阅链接（用于 update-sub）"
    echo "  --save-url      同时保存订阅URL到配置文件"
    echo "  --proxy         使用代理下载订阅（默认不走代理）"
    echo "  -h, --help      显示帮助"
    echo ""
    echo "示例:"
    echo "  mihomo-manager status              # 或 mihomo-manager st"
    echo "  mihomo-manager restart             # 或 mihomo-manager r"
    echo "  mihomo-manager save-url https://xxx.com/subscribe?token=xxx"
    echo "  mihomo-manager su https://xxx.com/subscribe?token=xxx"
    echo "  mihomo-manager update-sub -u 'https://xxx.com/subscribe?token=xxx' --save-url"
    echo "  mihomo-manager update              # 或 mihomo-manager upd"
    echo "  mihomo-manager list                # 或 mihomo-manager ls"
    echo "  mihomo-manager switch '移动-台北01' # 或 mihomo-manager swc '移动-台北01'"
    echo "  mihomo-manager test-nodes          # 或 mihomo-manager tn"
    echo "  mihomo-manager fastest             # 或 mihomo-manager f"
    echo "  mihomo-manager whitelist add example.com  # 或 mm wl add ..."
}

# 打印带颜色的信息
print_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

print_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

print_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# 端口配置（可通过环境变量覆盖）
MIXED_PORT="${MIHOMO_MIXED_PORT:-10808}"
SOCKS_PORT="${MIHOMO_SOCKS_PORT:-7891}"
API_PORT="${MIHOMO_API_PORT:-9090}"

# 缓存的服务状态
_CACHED_STATUS=""

# 检查服务状态（带缓存）
check_status() {
    if [ -n "$_CACHED_STATUS" ]; then
        echo "$_CACHED_STATUS"
        return
    fi
    local pid
    pid=$(pgrep -f "mihomo -f config.yaml" | head -1)
    if [ -n "$pid" ]; then
        _CACHED_STATUS="running:$pid"
    else
        _CACHED_STATUS="stopped"
    fi
    echo "$_CACHED_STATUS"
}

# 清除状态缓存
clear_status_cache() {
    _CACHED_STATUS=""
}

# 显示状态
show_status() {
    print_info "检查 Mihomo 服务状态..."

    local status
    status=$(check_status)

    if [ "$status" = "stopped" ]; then
        print_warning "服务未运行"
    else
        local pid
        pid=$(echo "$status" | cut -d: -f2)
        print_success "服务运行中 (PID: $pid)"

        # 检查端口（使用配置变量）
        if lsof -Pi :$MIXED_PORT -sTCP:LISTEN -t >/dev/null 2>&1; then
            print_success "混合代理端口 $MIXED_PORT: 监听中"
        else
            print_warning "混合代理端口 $MIXED_PORT: 未监听"
        fi

        if lsof -Pi :$SOCKS_PORT -sTCP:LISTEN -t >/dev/null 2>&1; then
            print_success "SOCKS 端口 $SOCKS_PORT: 监听中"
        else
            print_warning "SOCKS 端口 $SOCKS_PORT: 未监听"
        fi

        if lsof -Pi :$API_PORT -sTCP:LISTEN -t >/dev/null 2>&1; then
            print_success "管理面板 $API_PORT: 监听中 (http://127.0.0.1:$API_PORT)"
        else
            print_warning "管理面板 $API_PORT: 未监听"
        fi
    fi
}

# 启动服务
start_service() {
    clear_status_cache
    local status
    status=$(check_status)

    if [ "$status" != "stopped" ]; then
        print_warning "服务已在运行中"
        return 0
    fi

    print_info "启动 Mihomo 服务..."

    cd "$CONFIG_DIR"
    nohup "$MIHOMO_BIN" -f "$CONFIG_FILE" >> "$CONFIG_DIR/mihomo.log" 2>&1 &

    # 等待启动
    sleep 2

    clear_status_cache
    local new_status
    new_status=$(check_status)
    if [ "$new_status" != "stopped" ]; then
        print_success "服务启动成功 (PID: $(echo "$new_status" | cut -d: -f2))"
    else
        print_error "服务启动失败，请检查日志"
        return 1
    fi
}

# 停止服务
stop_service() {
    clear_status_cache
    local status
    status=$(check_status)

    if [ "$status" = "stopped" ]; then
        print_warning "服务未运行"
        return 0
    fi

    print_info "停止 Mihomo 服务..."

    local pid
    pid=$(echo "$status" | cut -d: -f2)
    kill "$pid" 2>/dev/null || true

    # 等待停止
    sleep 1

    # 强制停止
    if pgrep -f "mihomo" > /dev/null 2>&1; then
        pkill -9 mihomo 2>/dev/null || true
    fi

    clear_status_cache
    print_success "服务已停止"
}

# 重启服务
restart_service() {
    print_info "重启 Mihomo 服务..."
    stop_service
    sleep 1
    start_service
}

# 热重载配置
reload_config() {
    local status=$(check_status)
    
    if [ "$status" = "stopped" ]; then
        print_warning "服务未运行，直接启动..."
        start_service
        return 0
    fi
    
    print_info "测试配置文件..."
    if ! "$MIHOMO_BIN" -t -f "$CONFIG_FILE" > /dev/null 2>&1; then
        print_error "配置文件测试失败"
        "$MIHOMO_BIN" -t -f "$CONFIG_FILE"
        return 1
    fi
    
    print_success "配置文件测试通过"
    print_info "发送热重载信号..."
    
    local pid=$(echo "$status" | cut -d: -f2)
    kill -HUP "$pid" 2>/dev/null || true
    
    print_success "配置已热重载"
}

# 备份配置
backup_config() {
    print_info "备份当前配置..."
    
    local backup_name="config.yaml.$(date +%Y%m%d_%H%M%S).bak"
    cp "$CONFIG_FILE" "$CONFIG_DIR/$backup_name"
    cp "$CONFIG_FILE" "$CONFIG_BACKUP"
    
    print_success "配置已备份到:"
    print_success "  - $backup_name"
    print_success "  - config.yaml.bak"
}

# 恢复配置
restore_config() {
    if [ ! -f "$CONFIG_BACKUP" ]; then
        print_error "未找到备份文件: $CONFIG_BACKUP"
        return 1
    fi
    
    print_warning "这将覆盖当前配置，是否继续? (y/N)"
    read -r confirm
    
    if [ "$confirm" != "y" ] && [ "$confirm" != "Y" ]; then
        print_info "已取消"
        return 0
    fi
    
    # 先备份当前配置
    backup_config
    
    print_info "恢复备份配置..."
    cp "$CONFIG_BACKUP" "$CONFIG_FILE"
    
    print_success "配置已恢复"
    print_info "建议执行: mihomo-manager reload"
}

# 测试配置
test_config() {
    print_info "测试配置文件..."
    
    if "$MIHOMO_BIN" -t -f "$CONFIG_FILE"; then
        print_success "配置文件测试通过"
    else
        print_error "配置文件测试失败"
        return 1
    fi
}

# 查看日志
show_logs() {
    local log_file="$CONFIG_DIR/mihomo.log"
    
    if [ ! -f "$log_file" ]; then
        print_error "未找到日志文件: $log_file"
        return 1
    fi
    
    print_info "查看实时日志 (按 Ctrl+C 退出)..."
    
    # 先显示最近的 20 行历史日志
    echo ""
    echo "=== 最近 20 行日志 ==="
    tail -n 20 "$log_file"
    echo ""
    echo "=== 实时刷新中... ==="
    echo ""
    
    # 然后实时刷新
    tail -n 0 -f "$log_file"
}

# 编辑配置
edit_config() {
    local editor="${EDITOR:-vi}"

    print_info "使用编辑器: $editor"
    print_info "编辑配置文件: $CONFIG_FILE"

    $editor "$CONFIG_FILE"

    print_info "编辑完成，建议执行: mihomo-manager test"
}

# ========== 白名单管理功能 ==========

# 白名单标记（用于在配置文件中识别白名单规则）
WHITELIST_MARKER="# ===== 白名单（不走代理）====="
WHITELIST_END="# ===== 白名单结束 ====="

# 添加域名到白名单
whitelist_add() {
    local domain="$1"

    if [ -z "$domain" ]; then
        print_error "请指定要添加的域名"
        print_info "用法: mm whitelist add <域名>"
        print_info "示例: mm whitelist add example.com"
        return 1
    fi

    # 清理域名（移除可能的协议前缀）
    domain=$(echo "$domain" | sed -e 's|^https://||' -e 's|^http://||' -e 's|/.*$||')

    print_info "添加域名到白名单: $domain"

    # 检查配置文件是否存在
    if [ ! -f "$CONFIG_FILE" ]; then
        print_error "配置文件不存在: $CONFIG_FILE"
        return 1
    fi

    # 检查域名是否已存在
    if grep -q "DOMAIN-SUFFIX,$domain,🎯 Direct" "$CONFIG_FILE"; then
        print_warning "域名 $domain 已在白名单中"
        return 0
    fi
    if grep -q "DOMAIN,$domain,🎯 Direct" "$CONFIG_FILE"; then
        print_warning "域名 $domain 已在白名单中"
        return 0
    fi

    # 备份配置
    backup_config

    # 使用 Python 修改 YAML 文件（macOS sed 处理换行有问题）
    python3 << EOF
import re

with open('$CONFIG_FILE', 'r') as f:
    content = f.read()

marker = '$WHITELIST_MARKER'
end_marker = '$WHITELIST_END'
new_rule = f'- DOMAIN-SUFFIX,$domain,🎯 Direct    # 白名单: 直连'

if marker in content:
    # 在标记后添加
    content = content.replace(marker, marker + '\n' + new_rule)
else:
    # 在 rules: 后创建白名单区域
    content = content.replace('rules:', f'''rules:
{marker}
{new_rule}
{end_marker}''', 1)

with open('$CONFIG_FILE', 'w') as f:
    f.write(content)
EOF

    print_success "域名 $domain 已添加到白名单"
    print_info "规则已添加到 rules 区域顶部（优先匹配）"
    print_info "建议执行: mm reload 使配置生效"
}

# 从白名单移除域名
whitelist_remove() {
    local domain="$1"

    if [ -z "$domain" ]; then
        print_error "请指定要移除的域名"
        print_info "用法: mm whitelist remove <域名>"
        return 1
    fi

    # 清理域名
    domain=$(echo "$domain" | sed -e 's|^https://||' -e 's|^http://||' -e 's|/.*$||')

    print_info "从白名单移除域名: $domain"

    if [ ! -f "$CONFIG_FILE" ]; then
        print_error "配置文件不存在"
        return 1
    fi

    # 检查是否存在
    if ! grep -q "DOMAIN.*$domain.*🎯 Direct" "$CONFIG_FILE"; then
        print_warning "域名 $domain 不在白名单中"
        return 0
    fi

    # 备份配置
    backup_config

    # 删除该域名的白名单规则
    sed -i.tmp "/DOMAIN.*$domain.*🎯 Direct/d" "$CONFIG_FILE"
    rm -f "$CONFIG_FILE.tmp"

    print_success "域名 $domain 已从白名单移除"
    print_info "建议执行: mm reload 使配置生效"
}

# 列出白名单
whitelist_list() {
    print_info "当前白名单（直连域名）:"
    echo ""

    if [ ! -f "$CONFIG_FILE" ]; then
        print_error "配置文件不存在"
        return 1
    fi

    # 提取白名单规则
    local found=false
    local count=0

    while IFS= read -r line; do
        if echo "$line" | grep -q "🎯 Direct"; then
            # 提取域名
            local domain=$(echo "$line" | grep -o "DOMAIN[^,]*,[^,]*" | cut -d',' -f2)
            if [ -n "$domain" ]; then
                count=$((count + 1))
                found=true
                echo "  $count. $domain"
            fi
        fi
    done < "$CONFIG_FILE"

    if [ "$found" = false ]; then
        print_warning "白名单为空"
        echo ""
        print_info "使用以下命令添加:"
        print_info "  mm whitelist add <域名>"
        print_info "  mm wl add <域名>"
    else
        echo ""
        print_info "共 $count 个域名"
    fi
}

# 显示白名单帮助
whitelist_help() {
    echo "白名单管理 - 配置直连域名（不走代理）"
    echo ""
    echo "用法: mm whitelist <子命令> [参数]"
    echo "      mm wl <子命令> [参数]"
    echo ""
    echo "子命令:"
    echo "  add <域名>    添加域名到白名单"
    echo "  remove <域名> 从白名单移除域名"
    echo "  list          列出所有白名单域名"
    echo "  help          显示帮助"
    echo ""
    echo "示例:"
    echo "  mm whitelist add example.com     # 添加域名"
    echo "  mm wl add github.com             # 简写形式"
    echo "  mm whitelist remove example.com  # 移除域名"
    echo "  mm whitelist list                      # 查看列表"
}

# 处理白名单命令
whitelist_handler() {
    local subcmd="$1"
    local arg="$2"

    case "$subcmd" in
        add|a)
            whitelist_add "$arg"
            ;;
        remove|rm|r)
            whitelist_remove "$arg"
            ;;
        list|ls|l)
            whitelist_list
            ;;
        help|h|--help)
            whitelist_help
            ;;
        *)
            if [ -z "$subcmd" ]; then
                whitelist_list
            else
                # 可能是直接把域名当命令，尝试添加
                whitelist_add "$subcmd"
            fi
            ;;
    esac
}

# 列出所有节点
list_nodes() {
    print_info "获取节点列表..."
    
    local status=$(check_status)
    if [ "$status" = "stopped" ]; then
        print_error "服务未运行"
        return 1
    fi
    
    local response=$(curl -s "http://127.0.0.1:$API_PORT/proxies" 2>/dev/null)
    if [ -z "$response" ]; then
        print_error "无法获取节点列表"
        return 1
    fi
    
    echo "$response" | python3 -c "
import json
import sys

try:
    data = json.load(sys.stdin)
    proxies = data.get('proxies', {})
    
    for name, proxy in proxies.items():
        if proxy.get('type') == 'Selector':
            print(f'\n📁 代理组: {name}')
            print(f'   当前节点: {proxy.get(\"now\", \"N/A\")}')
            print(f'   可用节点: {len(proxy.get(\"all\", []))} 个')
            for node in proxy.get('all', [])[:20]:
                marker = '✓' if node == proxy.get('now') else ' '
                print(f'     [{marker}] {node}')
            if len(proxy.get('all', [])) > 20:
                print(f'     ... 还有 {len(proxy.get(\"all\", [])) - 20} 个节点')
except Exception as e:
    print(f'解析错误: {e}')
    sys.exit(1)
"
}

# 显示当前节点
show_current_node() {
    local status=$(check_status)
    if [ "$status" = "stopped" ]; then
        print_error "服务未运行"
        return 1
    fi
    
    local response=$(curl -s "http://127.0.0.1:$API_PORT/proxies/GLOBAL" 2>/dev/null)
    if [ -z "$response" ]; then
        return 1
    fi
    
    local current=$(echo "$response" | python3 -c "import json,sys; print(json.load(sys.stdin).get('now','N/A'))" 2>/dev/null)
    echo "🌐 当前节点: $current"
}

# 切换到指定节点
switch_node() {
    local node_name="$1"
    
    if [ -z "$node_name" ]; then
        print_error "请指定节点名称"
        return 1
    fi
    
    print_info "切换节点到: $node_name"
    
    local status=$(check_status)
    if [ "$status" = "stopped" ]; then
        print_error "服务未运行"
        return 1
    fi
    
    local response=$(curl -s -X PUT "http://127.0.0.1:$API_PORT/proxies/GLOBAL" \
        -H "Content-Type: application/json" \
        -d "{\"name\":\"$node_name\"}" 2>/dev/null)
    
    if [ $? -eq 0 ]; then
        print_success "节点切换成功"
        show_current_node
    else
        print_error "节点切换失败"
        return 1
    fi
}

# 测试节点延迟
test_nodes() {
    local limit="${1:-0}"  # 0 表示测试全部

    print_info "获取节点列表..."

    local status=$(check_status)
    if [ "$status" = "stopped" ]; then
        print_error "服务未运行"
        return 1
    fi

    # 获取所有代理信息
    local proxies_response=$(curl -s "http://127.0.0.1:$API_PORT/proxies" 2>/dev/null)
    if [ -z "$proxies_response" ]; then
        print_error "无法获取代理信息"
        return 1
    fi

    echo "正在分析节点信息..."

    # 使用 Python 解析节点列表（保存到变量）
    # 只获取真正的代理节点，排除代理组和特殊节点
    local nodes_list
    nodes_list=$(echo "$proxies_response" | python3 -c "
import json
import sys

try:
    data = json.load(sys.stdin)
    proxies = data.get('proxies', {})
    global_proxy = proxies.get('GLOBAL', {})
    all_nodes = global_proxy.get('all', [])

    # 代理组类型（排除）
    group_types = ['Selector', 'URLTest', 'Fallback', 'LoadBalance', 'Direct', 'Reject', 'RejectDrop', 'Pass', 'Compatible']

    for node_name in all_nodes:
        # 排除特殊节点
        if node_name in ['DIRECT', 'REJECT']:
            continue

        # 排除官网/有效期等特殊节点（通过关键词匹配）
        if node_name.startswith('官网') or node_name.startswith('有效期'):
            continue

        # 获取节点信息
        node_info = proxies.get(node_name, {})
        node_type = node_info.get('type', '')

        # 排除代理组（只保留真正的代理节点）
        if node_type in group_types:
            continue

        # 只输出真正的代理节点
        print(node_name)
except Exception as e:
    print(f'Error: {e}', file=sys.stderr)
    pass
")

    # 保存节点列表到临时文件用于后续处理
    local nodes_file="/tmp/mihomo_nodes_$$.txt"
    echo "$nodes_list" > "$nodes_file"

    # 同时保存第一个节点作为备选
    local first_node
    first_node=$(echo "$nodes_list" | head -1)

    # 统计节点数量
    local total_nodes=$(echo "$nodes_list" | wc -l | tr -d ' ')

    echo ""
    if [ "$limit" -gt 0 ]; then
        echo "正在测试节点延迟 (最多 $limit 个，每个最多 5 秒)..."
    else
        echo "正在测试所有节点延迟 (共 $total_nodes 个，每个最多 5 秒)..."
    fi
    echo ""

    local results_file="/tmp/mihomo_results_$$.txt"
    > "$results_file"

    # 保存完整结果到文件
    local speed_file="$CONFIG_DIR/node_speed.txt"
    echo "=== 节点速度测试结果 $(date '+%Y-%m-%d %H:%M:%S') ===" > "$speed_file"
    echo "" >> "$speed_file"

    local test_count=0
    local success_count=0

    while IFS= read -r node_name; do
        # 检查是否达到限制
        if [ "$limit" -gt 0 ] && [ "$test_count" -ge "$limit" ]; then
            break
        fi

        test_count=$((test_count + 1))

        # URL 编码节点名称 - 使用临时文件避免命令替换问题
        python3 -c "import urllib.parse; print(urllib.parse.quote('''$node_name''', safe=''))" > /tmp/mihomo_encoded_$$.txt 2>/dev/null
        local encoded_name=$(cat /tmp/mihomo_encoded_$$.txt)
        rm -f /tmp/mihomo_encoded_$$.txt

        # 测试延迟
        local delay_response
        delay_response=$(curl -s --max-time 5 "http://127.0.0.1:$API_PORT/proxies/${encoded_name}/delay?timeout=3000&url=http://www.gstatic.com/generate_204" 2>/dev/null)

        local delay=9999
        if [ -n "$delay_response" ]; then
            echo "$delay_response" > /tmp/mihomo_delay_$$.json
            delay=$(python3 -c "import json; d=json.load(open('/tmp/mihomo_delay_$$.json')); print(d.get('delay', 9999))" 2>/dev/null || echo 9999)
            rm -f /tmp/mihomo_delay_$$.json
        fi

        local status="✗"
        local delay_str="超时"
        if [ "$delay" -lt 9999 ] 2>/dev/null; then
            status="✓"
            delay_str="${delay}ms"
            echo "$node_name:$delay" >> "$results_file"
            success_count=$((success_count + 1))
            # 保存到速度文件
            printf "%-30s %6s\n" "$node_name" "$delay_str" >> "$speed_file"
        else
            printf "%-30s %6s\n" "$node_name" "超时" >> "$speed_file"
        fi

        echo "  [$test_count/$total_nodes] $status $node_name: $delay_str"

        sleep 0.2
    done < "$nodes_file"

    rm -f "$nodes_file"

    echo ""
    echo "=== 测试结果 ==="

    if [ -s "$results_file" ]; then
        # 排序并显示前10个
        echo ""
        echo "📊 最快的 10 个节点:"
        sort -t: -k2 -n "$results_file" | head -10 | while IFS=: read -r name delay; do
            printf "  %-30s %6sms\n" "$name" "$delay"
        done

        # 保存最快节点
        local fastest=$(sort -t: -k2 -n "$results_file" | head -1 | cut -d: -f1)
        echo "$fastest" > "$CONFIG_DIR/fastest_node.txt"

        # 更新速度文件，添加排序后的结果
        echo "" >> "$speed_file"
        echo "=== 按速度排序 ===" >> "$speed_file"
        sort -t: -k2 -n "$results_file" | while IFS=: read -r name delay; do
            printf "%-30s %6sms\n" "$name" "$delay" >> "$speed_file"
        done

        echo ""
        echo "💡 最快节点: $fastest"
        echo ""
        echo "📁 完整结果已保存到: $speed_file"
        echo "   查看: cat $speed_file"
    else
        echo "  没有成功测试的节点"
        # 使用保存的第一个节点作为备选
        if [ -n "$first_node" ]; then
            echo "$first_node" > "$CONFIG_DIR/fastest_node.txt"
            echo ""
            echo "⚠️ 使用第一个节点作为备选: $first_node"
        fi
    fi

    echo ""
    echo "📈 统计: 测试 $test_count 个节点，成功 $success_count 个"

    rm -f "$results_file"
}

# 自动切换到最快节点
switch_to_fastest() {
    print_info "自动选择最快节点..."

    local status=$(check_status)
    if [ "$status" = "stopped" ]; then
        print_error "服务未运行"
        return 1
    fi

    # 测试所有节点（0 表示全部）
    test_nodes 0

    if [ -f "$CONFIG_DIR/fastest_node.txt" ]; then
        local fastest=$(cat "$CONFIG_DIR/fastest_node.txt")
        echo ""
        print_info "最快节点: $fastest"
        switch_node "$fastest"
    else
        print_error "未找到最快节点记录"
        return 1
    fi
}

# 从订阅链接下载配置
download_subscription() {
    local url="$1"
    local use_proxy="$2"

    if [ -z "$url" ]; then
        print_error "请提供订阅链接"
        print_info "用法: mihomo-manager update-sub -u '订阅链接' [--proxy]"
        return 1
    fi

    print_info "下载订阅配置..."

    local temp_file="/tmp/mihomo_sub_$(date +%s).yaml"
    local download_success=false

    # 根据是否使用代理选择下载方式
    if [ "$use_proxy" = "true" ]; then
        print_info "使用代理下载 (http://127.0.0.1:$MIXED_PORT)..."
        if command -v curl >/dev/null 2>&1; then
            if curl -fsSL -x "http://127.0.0.1:$MIXED_PORT" "$url" -o "$temp_file" 2>/dev/null; then
                download_success=true
            fi
        elif command -v wget >/dev/null 2>&1; then
            if wget -q -e "use_proxy=yes" -e "http_proxy=http://127.0.0.1:$MIXED_PORT" "$url" -O "$temp_file" 2>/dev/null; then
                download_success=true
            fi
        fi

        if [ "$download_success" != "true" ]; then
            print_error "使用代理下载失败"
            rm -f "$temp_file"
            return 1
        fi
    else
        print_info "直接下载（不走代理）..."
        # 临时取消代理环境变量
        local old_http_proxy="$http_proxy"
        local old_https_proxy="$https_proxy"
        local old_HTTP_PROXY="$HTTP_PROXY"
        local old_HTTPS_PROXY="$HTTPS_PROXY"
        unset http_proxy https_proxy HTTP_PROXY HTTPS_PROXY

        if command -v curl >/dev/null 2>&1; then
            print_info "尝试使用 curl 下载..."
            # --proxy "" 强制不走代理
            if curl -fsSL --proxy "" "$url" -o "$temp_file" 2>&1; then
                download_success=true
            else
                print_error "curl 下载失败，错误代码: $?"
                print_info "尝试使用 curl -v 查看详细信息..."
                curl -v -fsSL --proxy "" "$url" -o /dev/null 2>&1 | tail -20
            fi
        elif command -v wget >/dev/null 2>&1; then
            print_info "尝试使用 wget 下载..."
            # --no-proxy 强制不走代理
            if wget -q --no-proxy "$url" -O "$temp_file" 2>&1; then
                download_success=true
            else
                print_error "wget 下载失败，错误代码: $?"
                print_info "尝试使用 wget 详细模式..."
                wget --no-proxy -S --max-redirect=5 "$url" -O /dev/null 2>&1 | tail -20
            fi
        else
            print_error "未找到 curl 或 wget"
            # 恢复代理环境变量
            export http_proxy="$old_http_proxy"
            export https_proxy="$old_https_proxy"
            export HTTP_PROXY="$old_HTTP_PROXY"
            export HTTPS_PROXY="$old_HTTPS_PROXY"
            return 1
        fi

        # 恢复代理环境变量
        export http_proxy="$old_http_proxy"
        export https_proxy="$old_https_proxy"
        export HTTP_PROXY="$old_HTTP_PROXY"
        export HTTPS_PROXY="$old_HTTPS_PROXY"

        if [ "$download_success" != "true" ]; then
            print_error "下载失败"
            print_info "如果订阅需要代理访问，请使用 --proxy 选项"
            print_info "或者手动下载后使用: mm reload"
            rm -f "$temp_file"
            return 1
        fi
    fi

    # 验证下载的文件
    if [ ! -s "$temp_file" ]; then
        print_error "下载的文件为空"
        rm -f "$temp_file"
        return 1
    fi

    # 检测订阅格式：是完整 YAML 还是纯节点订阅
    local first_line
    first_line=$(head -1 "$temp_file")

    if echo "$first_line" | grep -q "^vless://\|^vmess://\|^ss://\|^trojan://\|^hysteria://\|^hysteria2://"; then
        print_info "检测到节点订阅格式，正在转换为完整配置..."

        # 使用 Python 解析节点并合并到现有配置
        if ! python3 << 'PYTHON_SCRIPT'; then
import yaml
import base64
import urllib.parse
import re
import sys

# 读取下载的节点订阅
with open('$temp_file', 'r') as f:
    sub_content = f.read()

# 解码 base64（如果是编码格式）
try:
    # 尝试 base64 解码
    decoded = base64.b64decode(sub_content.strip()).decode('utf-8')
    lines = decoded.strip().split('\n')
except:
    # 不是 base64，直接使用原始内容
    lines = sub_content.strip().split('\n')

# 解析节点
proxies = []
proxy_names = []

for line in lines:
    line = line.strip()
    if not line or line.startswith('#'):
        continue

    # 解析 vless 链接
    if line.startswith('vless://'):
        try:
            # vless://uuid@host:port?params#name
            match = re.match(r'vless://([^@]+)@([^:]+):(\d+)?\?(.*)#(.*)', line)
            if match:
                uuid, host, port, params, name = match.groups()
                name = urllib.parse.unquote(name or '未命名节点')

                proxy = {
                    'name': name,
                    'type': 'vless',
                    'server': host,
                    'port': int(port or 443),
                    'uuid': uuid,
                    'cipher': 'auto',
                    'udp': True
                }

                # 解析参数
                param_dict = {}
                for p in params.split('&'):
                    if '=' in p:
                        k, v = p.split('=', 1)
                        param_dict[k] = urllib.parse.unquote(v)

                if param_dict.get('type') == 'tcp':
                    proxy['network'] = 'tcp'
                elif param_dict.get('type') == 'ws':
                    proxy['network'] = 'ws'
                    proxy['ws-opts'] = {'path': param_dict.get('path', '/'), 'headers': {'Host': param_dict.get('host', host)}}
                elif param_dict.get('type') == 'grpc':
                    proxy['network'] = 'grpc'
                    proxy['grpc-opts'] = {'grpc-service-name': param_dict.get('serviceName', param_dict.get('path', ''))}

                if param_dict.get('security') == 'reality':
                    proxy['tls'] = True
                    proxy['servername'] = param_dict.get('sni', host)
                    proxy['reality-opts'] = {
                        'public-key': param_dict.get('pbk', ''),
                        'short-id': param_dict.get('sid', '')
                    }
                    proxy['client-fingerprint'] = param_dict.get('fp', 'chrome')
                elif param_dict.get('security') == 'tls':
                    proxy['tls'] = True
                    proxy['servername'] = param_dict.get('sni', host)

                if param_dict.get('flow'):
                    proxy['flow'] = param_dict['flow']

                proxies.append(proxy)
                proxy_names.append(name)
        except Exception as e:
            print(f'解析节点失败: {line[:50]}... 错误: {e}', file=sys.stderr)

    # 解析 vmess 链接
    elif line.startswith('vmess://'):
        try:
            # vmess://base64_encoded_json
            encoded = line.replace('vmess://', '')
            decoded_json = base64.b64decode(encoded).decode('utf-8')
            config = eval(decoded_json)  # 简单解析

            proxy = {
                'name': config.get('ps', '未命名节点'),
                'type': 'vmess',
                'server': config.get('add', ''),
                'port': int(config.get('port', 443)),
                'uuid': config.get('id', ''),
                'cipher': config.get('scy', 'auto'),
                'alterId': int(config.get('aid', 0)),
                'udp': True
            }

            if config.get('tls') == 'tls':
                proxy['tls'] = True
                proxy['servername'] = config.get('host', config.get('add', ''))

            if config.get('net') == 'ws':
                proxy['network'] = 'ws'
                proxy['ws-opts'] = {'path': config.get('path', '/'), 'headers': {'Host': config.get('host', config.get('add', ''))}}

            proxies.append(proxy)
            proxy_names.append(proxy['name'])
        except Exception as e:
            print(f'解析 vmess 节点失败: {e}', file=sys.stderr)

    # 解析 trojan 链接
    elif line.startswith('trojan://'):
        try:
            match = re.match(r'trojan://([^@]+)@([^:]+):(\d+)?\?(.*)#(.*)', line)
            if match:
                password, host, port, params, name = match.groups()
                name = urllib.parse.unquote(name or '未命名节点')

                proxy = {
                    'name': name,
                    'type': 'trojan',
                    'server': host,
                    'port': int(port or 443),
                    'password': password,
                    'udp': True,
                    'skip-cert-verify': False
                }

                proxies.append(proxy)
                proxy_names.append(name)
        except Exception as e:
            print(f'解析 trojan 节点失败: {e}', file=sys.stderr)

    # 解析 ss 链接
    elif line.startswith('ss://'):
        try:
            # ss://base64(method:password)@host:port#name 或 ss://base64#name
            match = re.match(r'ss://([^@]+)@([^:]+):(\d+)#(.*)', line)
            if match:
                encoded, host, port, name = match.groups()
                decoded = base64.b64decode(encoded).decode('utf-8')
                method, password = decoded.split(':', 1)
                name = urllib.parse.unquote(name or '未命名节点')

                proxy = {
                    'name': name,
                    'type': 'ss',
                    'server': host,
                    'port': int(port),
                    'cipher': method,
                    'password': password,
                    'udp': True
                }
                proxies.append(proxy)
                proxy_names.append(name)
        except Exception as e:
            print(f'解析 ss 节点失败: {e}', file=sys.stderr)

if not proxies:
    print('没有解析到有效节点', file=sys.stderr)
    sys.exit(1)

print(f'成功解析 {len(proxies)} 个节点')

# 读取现有配置
with open('$CONFIG_FILE', 'r') as f:
    config = yaml.safe_load(f)

if not config:
    print('无法读取现有配置', file=sys.stderr)
    sys.exit(1)

# 保留特殊节点（DIRECT, REJECT 等）
special_nodes = ['DIRECT', 'REJECT']
existing_proxies = config.get('proxies', [])
for p in existing_proxies:
    name = p.get('name', '')
    # 保留官网/有效期等特殊节点
    if name.startswith('官网') or name.startswith('有效期'):
        proxies.insert(0, p)
    if p.get('name') in special_nodes:
        proxies.insert(0, p)

# 更新 proxies
config['proxies'] = proxies

# 更新 proxy-groups 中的节点列表
for group in config.get('proxy-groups', []):
    if group.get('type') == 'select' and group.get('name') not in ['🎯 Direct', '🛑 Block', '🐟 漏网之鱼']:
        # 保留特殊节点
        new_proxies = [p for p in group.get('proxies', []) if p in special_nodes]
        # 添加新节点
        new_proxies.extend(proxy_names)
        group['proxies'] = new_proxies

# 写入新配置
with open('$CONFIG_FILE', 'w') as f:
    yaml.dump(config, f, allow_unicode=True, default_flow_style=False, sort_keys=False)

print('配置已更新')
PYTHON_SCRIPT
            print_error "节点解析失败"
            rm -f "$temp_file"
            return 1
        fi

        rm -f "$temp_file"
        print_success "订阅节点已合并到配置文件"
        print_info "建议执行: mm reload 或 mm restart"

    else
        print_info "检测到完整 YAML 配置格式..."

        # 测试配置文件
        print_info "验证下载的配置..."
        if ! "$MIHOMO_BIN" -t -f "$temp_file" > /dev/null 2>&1; then
            print_error "下载的配置文件无效"
            print_warning "可能是订阅链接已过期或格式不正确"
            rm -f "$temp_file"
            return 1
        fi

        # 备份当前配置
        backup_config

        # 替换配置
        print_info "更新配置文件..."
        mv "$temp_file" "$CONFIG_FILE"
        chmod 600 "$CONFIG_FILE"

        print_success "订阅配置已更新"
        print_info "建议执行: mihomo-manager reload 或 mihomo-manager restart"
    fi
}

# 保存订阅 URL
save_subscription_url() {
    local url="$1"

    if [ -z "$url" ]; then
        print_error "请提供订阅 URL"
        print_info "用法: mihomo-manager save-url 'https://xxx.com/subscribe?token=xxx'"
        return 1
    fi

    print_info "保存订阅 URL..."
    echo "$url" > "$SUBSCRIPTION_URL_FILE"
    chmod 600 "$SUBSCRIPTION_URL_FILE"
    print_success "订阅 URL 已保存到: $SUBSCRIPTION_URL_FILE"
}

# 显示保存的订阅 URL
show_subscription_url() {
    if [ ! -f "$SUBSCRIPTION_URL_FILE" ]; then
        print_warning "未找到保存的订阅 URL"
        print_info "使用以下命令保存:"
        print_info "  mihomo-manager save-url 'https://xxx.com/subscribe?token=xxx'"
        return 1
    fi

    local url=$(cat "$SUBSCRIPTION_URL_FILE")
    if [ -z "$url" ]; then
        print_warning "保存的订阅 URL 为空"
        return 1
    fi

    print_info "已保存的订阅 URL:"
    echo "  $url"
}

# 从保存的订阅 URL 更新
update_from_saved_url() {
    print_info "从保存的订阅 URL 更新配置..."

    if [ ! -f "$SUBSCRIPTION_URL_FILE" ]; then
        print_error "未找到保存的订阅 URL"
        print_info "请先使用以下命令保存订阅 URL:"
        print_info "  mihomo-manager save-url 'https://xxx.com/subscribe?token=xxx'"
        print_info ""
        print_info "或使用 update-sub 直接指定 URL:"
        print_info "  mihomo-manager update-sub -u 'https://xxx.com/subscribe?token=xxx' --save-url"
        return 1
    fi

    local url=$(cat "$SUBSCRIPTION_URL_FILE")
    if [ -z "$url" ]; then
        print_error "保存的订阅 URL 为空"
        return 1
    fi

    print_info "使用订阅 URL:"
    echo "  $url"
    echo ""

    # 默认不走代理下载
    download_subscription "$url" "false"
}

# 主函数
main() {
    # 检查依赖（但不阻止帮助命令）
    if [ "${1:-}" != "-h" ] && [ "${1:-}" != "--help" ] && [ -n "${1:-}" ]; then
        check_dependencies
    fi

    local command=""
    local url=""
    local use_proxy="false"
    local save_url="false"
    local switch_node_name=""
    
    # 解析参数
    while [ $# -gt 0 ]; do
        case "$1" in
            -h|--help)
                show_help
                exit 0
                ;;
            -u|--url)
                if [ -n "$2" ] && [ "${2#-}" = "$2" ]; then
                    url="$2"
                    shift 2
                else
                    print_error "选项 --url 需要参数"
                    exit 1
                fi
                ;;
            --proxy)
                use_proxy="true"
                shift
                ;;
            --save-url)
                save_url="true"
                shift
                ;;
            -*)
                print_error "未知选项: $1"
                show_help
                exit 1
                ;;
            *)
                if [ -z "$command" ]; then
                    command="$1"
                    shift
                    # 对于 save-url/su 命令，收集所有剩余参数作为 URL（处理不带引号的情况）
                    if [ "$command" = "save-url" ] || [ "$command" = "su" ]; then
                        switch_node_name="$*"
                        break
                    fi
                    # 对于 switch/swc 命令，收集剩余参数作为节点名
                    if [ "$command" = "switch" ] || [ "$command" = "swc" ]; then
                        switch_node_name="$*"
                        break
                    fi
                    # 对于 whitelist/wl 命令，收集剩余参数
                    if [ "$command" = "whitelist" ] || [ "$command" = "wl" ]; then
                        switch_node_name="$*"
                        break
                    fi
                    # 对于其他命令，shift 已在上面执行，继续循环
                else
                    # 不应该到这里
                    print_error "多余的参数: $1"
                    exit 1
                fi
                ;;
        esac
    done
    
    # 检查命令
    if [ -z "$command" ]; then
        show_help
        exit 0
    fi
    
    # 执行命令（支持简短别名）
    case "$command" in
        status|st)
            show_status
            ;;
        start)
            start_service
            ;;
        stop|sp)
            stop_service
            ;;
        restart|r)
            restart_service
            ;;
        reload|rl)
            reload_config
            ;;
        update-sub|us)
            if download_subscription "$url" "$use_proxy"; then
                if [ "$save_url" = "true" ] && [ -n "$url" ]; then
                    save_subscription_url "$url"
                fi
            fi
            ;;
        update|upd)
            update_from_saved_url
            ;;
        save-url|su)
            save_subscription_url "$switch_node_name"
            ;;
        show-url|sw)
            show_subscription_url
            ;;
        backup|bk)
            backup_config
            ;;
        restore|rs)
            restore_config
            ;;
        test|t)
            test_config
            ;;
        logs|l)
            show_logs
            ;;
        edit|e)
            edit_config
            ;;
        list|ls)
            list_nodes
            ;;
        current|c)
            show_current_node
            ;;
        switch|swc)
            if [ -z "$switch_node_name" ]; then
                print_error "请指定节点名称"
                print_info "用法: mihomo-manager switch <节点名>"
                exit 1
            fi
            switch_node "$switch_node_name"
            ;;
        test-nodes|tn)
            test_nodes
            ;;
        fastest|f)
            switch_to_fastest
            ;;
        whitelist|wl)
            # 白名单命令使用 switch_node_name 传递的参数
            local wl_args="$switch_node_name"
            local wl_subcmd=$(echo "$wl_args" | awk '{print $1}')
            local wl_arg=$(echo "$wl_args" | awk '{print $2}')

            if [ "$wl_subcmd" = "add" ] || [ "$wl_subcmd" = "a" ]; then
                whitelist_add "$wl_arg"
            elif [ "$wl_subcmd" = "remove" ] || [ "$wl_subcmd" = "rm" ] || [ "$wl_subcmd" = "r" ]; then
                whitelist_remove "$wl_arg"
            elif [ "$wl_subcmd" = "list" ] || [ "$wl_subcmd" = "ls" ] || [ "$wl_subcmd" = "l" ]; then
                whitelist_list
            elif [ "$wl_subcmd" = "help" ] || [ "$wl_subcmd" = "h" ] || [ "$wl_subcmd" = "--help" ] || [ "$wl_subcmd" = "-h" ]; then
                whitelist_help
            elif [ -z "$wl_subcmd" ]; then
                whitelist_list
            else
                # 直接传入域名，默认执行 add
                whitelist_add "$wl_subcmd"
            fi
            ;;
        *)
            print_error "未知命令: $command"
            show_help
            exit 1
            ;;
    esac
}

# 运行主函数
main "$@"
